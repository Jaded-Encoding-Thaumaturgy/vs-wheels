{
  "folders": [
    {
      "name": "BM3D CPU",
      "path": "bm3dcuda/bm3dcpu",
    },
    {
      "name": "BM3D CUDA",
      "path": "bm3dcuda/bm3dcuda",
    },
    {
      "name": "BM3D HIP",
      "path": "bm3dcuda/bm3dhip",
    },
    {
      "name": "FMTCONV",
      "path": "fmtc",
    },
    {
      "name": "DFTTEST2 (PYTHON)",
      "path": "dfttest2/dfttest2",
    },
    {
      "name": "DFTTEST2 GCC",
      "path": "dfttest2/dfttest2_gcc",
    },
    {
      "name": "DFTTEST2 CPU",
      "path": "dfttest2/dfttest2_cpu",
    },
    {
      "name": "DFTTEST2 CUDA",
      "path": "dfttest2/dfttest2_cuda",
    },
    {
      "name": "DFTTEST2 NCRTC",
      "path": "dfttest2/dfttest2_nvrtc",
    },
    {
      "name": "DFTTEST2 HIPRTC",
      "path": "dfttest2/dfttest2_hiprtc",
    },
    {
      "name": "vs-wheels (Root)",
      "path": ".",
    },
  ],
  "settings": {
    "editor.formatOnSave": true,
    "[markdown]": {
      "editor.wordWrap": "on",
      "editor.tabSize": 2,
    },
    "[json]": {
      "editor.defaultFormatter": "esbenp.prettier-vscode",
      "editor.tabSize": 2,
    },
    "[toml]": {
      "editor.defaultFormatter": "tamasfe.even-better-toml",
      "editor.tabSize": 4,
    },
    "[github-actions-workflow]": {
      "editor.defaultFormatter": "esbenp.prettier-vscode",
      "editor.tabSize": 2,
    },
    "[powershell]": {
      "debug.saveBeforeStart": "nonUntitledEditorsInActiveGroup",
      "editor.semanticHighlighting.enabled": false,
      "editor.wordSeparators": "`~!@#$%^&*()=+[{]}\\|;:'\",.<>/?",
      "editor.defaultFormatter": "ms-vscode.powershell",
    },
    "cmake.sourceDirectory": "${workspaceFolder}",
    "powershell.cwd": "vs-wheels (Root)",
    "yaml.schemas": {
      "https://www.schemastore.org/github-action.json": "**/.github/actions/**/*.yml",
    },
    "files.associations": {
      "**/.github/workflows/*.yml": "github-actions-workflow",
      "**/.github/actions/**/action.yml": "github-actions-workflow",
    },
  },
  "extensions": {
    "recommendations": [
      "skellock.just",
      "tamasfe.even-better-toml",
      "esbenp.prettier-vscode",
      "ms-vscode.cmake-tools",
      "ms-python.python",
      "charliermarsh.ruff",
      "ms-vscode.powershell",
    ],
  },
}
